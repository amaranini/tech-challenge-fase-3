# ---- Dados sensíveis (PII médica, datasets pesados) ----
# Não commitar nada de data/raw e data/processed por padrão.
data/raw/*
data/processed/*
data/synthetic/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/synthetic/.gitkeep

# Vector DB persistido
data/chroma/


# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.eggs/
build/
dist/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.ipynb_checkpoints/

# Ambientes virtuais
.venv/
venv/
.uv/

# ---- macOS ----
.DS_Store
.AppleDouble
.LSOverride

# ---- Variáveis de ambiente ----
.env
.env.local
.env.*.local

# ---- Dados sensíveis (PII médica, datasets pesados) ----
# Regra geral: dados crus e sintéticos (pré-anonimização) ficam fora do git.
# Exceção: arquivos finais já anonimizados em data/processed/ vão pro git,
# pois são entregáveis reprodutíveis do projeto.
data/raw/*
data/synthetic/*
data/processed/*
!data/raw/.gitkeep
!data/synthetic/.gitkeep
!data/processed/.gitkeep
!data/processed/*.jsonl
!data/processed/*.md

# Vector DB persistido
data/chroma/

# ---- Fase 4: índice RAG (Chroma) e banco de pacientes (SQLite) ----
# Ambos são reconstruídos pelos scripts de build a partir de data/synthetic/.
assistant/data/

# ---- Saídas de fine-tuning (modelos pesados) ----
# Dataset convertido pro formato MLX é regenerável → ignorar.
finetuning/data/

# Outputs: ignorar tudo exceto os entregáveis finais (adapter, log e gráficos).
finetuning/output/*
!finetuning/output/.gitkeep
!finetuning/output/training_log.json
!finetuning/output/loss_curve.png
!finetuning/output/lr_schedule.png
!finetuning/output/adapters/
finetuning/output/adapters/*
!finetuning/output/adapters/adapters.safetensors
!finetuning/output/adapters/adapter_config.json

# Formatos gerais de modelos pesados (em qualquer outro lugar).
*.gguf
*.bin
*.pt
*.ckpt

# ---- Logs de auditoria ----
logging_/logs/*
!logging_/logs/.gitkeep
# Logs estruturados gerados em runtime pelo grafo (Fase 5).
# Schema documentado em assistant/graph_state.py (AlertEntry, NodeTraceEntry).
logging_/*.jsonl

# ---- IDE / Editores ----
.vscode/
.idea/
*.swp
*.swo
*~

# ---- Misc ----
.coverage
htmlcov/

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.eggs/
build/
dist/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.ipynb_checkpoints/

# Ambientes virtuais
.venv/
venv/
.uv/

# ---- macOS ----
.DS_Store
.AppleDouble
.LSOverride

# ---- Variáveis de ambiente ----
.env
.env.local
.env.*.local

# ---- Dados sensíveis (PII médica, datasets pesados) ----
# Regra geral: dados crus e sintéticos (pré-anonimização) ficam fora do git.
# Exceção: arquivos finais já anonimizados em data/processed/ vão pro git,
# pois são entregáveis reprodutíveis do projeto.
data/raw/*
data/synthetic/*
data/processed/*
!data/raw/.gitkeep
!data/synthetic/.gitkeep
!data/processed/.gitkeep
!data/processed/*.jsonl
!data/processed/*.md

# Vector DB persistido
data/chroma/

# ---- Saídas de fine-tuning (modelos pesados) ----
finetuning/outputs/
*.gguf
*.safetensors
*.bin
*.pt
*.ckpt

# ---- Logs de auditoria ----
logging_/logs/*
!logging_/logs/.gitkeep

# ---- IDE / Editores ----
.vscode/
.idea/
*.swp
*.swo
*~

# ---- Misc ----
.coverage
htmlcov/

# Copie este arquivo para `.env` e ajuste os valores.
# O arquivo `.env` NUNCA deve ser commitado (já está no .gitignore).

# ----- OpenAI -----
# Usada na Fase 1 para gerar o dataset sintético via gpt-4o-mini.
# Pegue sua chave em: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# Modelo de geração sintética (não trocar sem motivo — custo está calibrado).
OPENAI_MODEL=gpt-4o-mini

# ----- Inferência local -----
# Backend que vai rodar o modelo no Mac: "mlx" (preferido) ou "ollama" (fallback).
INFERENCE_BACKEND=mlx

# Modelo base (HuggingFace ID ou caminho local).
# Usamos a versão bf16 do Qwen2.5-1.5B (única que permite LoRA no MLX).
MODEL_PATH=mlx-community/Qwen2.5-1.5B-Instruct-bf16

# Diretório do adapter LoRA treinado na Fase 2.
ADAPTER_PATH=./finetuning/output/adapters

# Defaults de geração.
# Temperatura baixa (0.0 = determinístico, 1.0 = criativo). Para contexto
# clínico queremos respostas consistentes, sem floreio criativo.
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=512
LLM_TOP_P=0.95

# ----- RAG -----
# Score mínimo (cosseno) pra um chunk ser usado no prompt. Chunks abaixo
# são descartados — protege contra "lixo semântico" em queries fora do
# escopo dos protocolos.
#
# Calibração empírica em 2026-05-26 com 25 queries (10 PRESENT + 10 ABSENT
# + 5 BORDERLINE): em 0.55 recall=90% e specificity=80%; em 0.50 recall=90%
# e specificity=70% (mesmo recall, pior specificity → 0.55 Pareto-domina).
#
# Detalhes: evaluation/rag_threshold_calibration_results.md
# Reproduzir: uv run python evaluation/calibrate_rag_threshold.py
RAG_MIN_SCORE=0.55

# ----- API (FastAPI) -----
API_HOST=0.0.0.0
API_PORT=8000

# ----- UI (Streamlit) -----
UI_PORT=8501
# URL da API que o Streamlit vai chamar.
API_BASE_URL=http://localhost:8000

# ----- Vector DB (Chroma) -----
# Diretório onde o Chroma persiste os embeddings da base de conhecimento.
CHROMA_PERSIST_DIR=./data/chroma
# Modelo de embeddings (sentence-transformers).
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ----- Logging / Auditoria -----
LOG_LEVEL=INFO
# Arquivo onde toda interação fica registrada (compliance).
AUDIT_LOG_PATH=./logging_/logs/audit.jsonl

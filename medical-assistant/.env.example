# Copie este arquivo para `.env` e ajuste os valores.
# O arquivo `.env` NUNCA deve ser commitado (já está no .gitignore).

# ----- Inferência local -----
# Backend que vai rodar o modelo no Mac: "mlx" (preferido) ou "ollama" (fallback).
INFERENCE_BACKEND=mlx

# Caminho do modelo fine-tuned (será preenchido depois do treino no Colab).
# Para MLX: pasta com os arquivos do modelo convertido.
# Para Ollama: nome do modelo registrado (ex: "qwen2.5-medical:latest").
MODEL_PATH=./finetuning/outputs/qwen2.5-3b-medical

# Temperatura padrão da geração (0.0 = determinístico, 1.0 = criativo).
LLM_TEMPERATURE=0.2

# ----- API (FastAPI) -----
API_HOST=0.0.0.0
API_PORT=8000

# ----- UI (Streamlit) -----
UI_PORT=8501
# URL da API que o Streamlit vai chamar.
API_BASE_URL=http://localhost:8000

# ----- Vector DB (Chroma) -----
# Diretório onde o Chroma persiste os embeddings da base de conhecimento.
CHROMA_PERSIST_DIR=./data/chroma
# Modelo de embeddings (sentence-transformers).
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ----- Logging / Auditoria -----
LOG_LEVEL=INFO
# Arquivo onde toda interação fica registrada (compliance).
AUDIT_LOG_PATH=./logging_/logs/audit.jsonl
